---
// src/components/sections/Testimonials.astro

const reviews = [
  {
    initial: "I",
    name: "Isabela Farias",
    text: "Querida e com um olhar que transmite acolhimento. É uma profissional competente, atende com tranquilidade, permitindo que o paciente se expresse e demonstra uma escuta muito atenta."
  },
  {
    initial: "J",
    name: "Jaime Alves",
    text: "Ótima profissional, trata minha filha de 8 anos, com muita paciência e carinho, super recomendo."
  },
  {
    initial: "I",
    name: "Isabella de Souza Costa",
    text: "Excelente profissional! Muito atenciosa, humana e cuidadosa no acompanhamento. Minha filha se sente acolhida e tivemos mudanças muito positivas após o início das consultas. Recomendo muito!"
  }
];
---

<section id="depoimentos" class="scroll-mt-24 py-20 md:py-32 px-4 md:px-8 bg-surface relative overflow-hidden">
  
  <!-- Detalhe decorativo de fundo -->
  <div class="absolute top-1/2 left-0 w-64 h-64 bg-accent-light rounded-full blur-3xl -z-10 pointer-events-none opacity-50"></div>

  <div class="max-w-6xl mx-auto">
    
    <!-- Cabeçalho da Seção -->
    <div class="text-center max-w-2xl mx-auto mb-16 md:mb-20 space-y-4">
      <div class="flex items-center justify-center gap-2 mb-2">
        <!-- Ícone simples do Google (G) -->
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <span class="text-sm font-semibold text-text-secondary uppercase tracking-wider">Avaliações no Google</span>
      </div>
      
      <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-text-primary leading-tight">
        O que dizem sobre o <span class="italic text-accent">atendimento</span>
      </h2>
    </div>

    <!-- Grid de Avaliações -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      
      {reviews.map((review) => (
        <article class="bg-background border border-border rounded-3xl p-6 md:p-8 flex flex-col h-full hover:shadow-lg hover:shadow-accent/5 transition-shadow duration-500">
          
          <!-- Estrelas -->
          <div class="flex gap-1 mb-4 text-amber-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>

          <!-- Texto do Depoimento -->
          <p class="text-text-secondary leading-relaxed mb-6 flex-grow italic">
            "{review.text}"
          </p>

          <!-- Autor -->
          <div class="flex items-center gap-4 pt-4 border-t border-border">
            <!-- Avatar com Inicial -->
            <div class="w-10 h-10 rounded-full bg-accent-light text-accent flex items-center justify-center font-display font-bold text-lg flex-shrink-0">
              {review.initial}
            </div>
            <div>
              <p class="font-semibold text-text-primary text-sm">{review.name}</p>
              <p class="text-xs text-text-secondary flex items-center gap-1 mt-0.5">
                <span>Via Google Maps</span>
              </p>
            </div>
          </div>

        </article>
      ))}

    </div>
  </div>
</section>