---
// src/components/sections/Services.astro
import { siteConfig } from '../../data/site-config';
---

<section id="servicos" class="scroll-mt-24 py-20 md:py-32 px-4 md:px-8 bg-background relative overflow-hidden">
  
  <!-- Detalhe decorativo de fundo -->
  <div class="absolute bottom-0 right-0 w-80 h-80 bg-accent-light rounded-full blur-3xl -z-10 pointer-events-none opacity-60"></div>

  <div class="max-w-6xl mx-auto">
    
    <!-- Cabeçalho da Seção -->
    <div class="text-center max-w-2xl mx-auto mb-16 md:mb-20 space-y-4">
      <span class="inline-block px-4 py-1.5 rounded-full bg-accent-light text-accent text-xs font-semibold tracking-wide uppercase">
        Áreas de Atuação
      </span>
      
      <!-- Título simplificado e à prova de erros -->
      <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-text-primary leading-tight">
        {siteConfig.servicos?.titulo || 'Como posso te ajudar hoje?'}
      </h2>
      
      <p class="text-text-secondary text-lg leading-relaxed">
        {siteConfig.servicos?.subtitulo || 'Ofereço diferentes formatos de terapia para se adequar à sua rotina.'}
      </p>
    </div>

    <!-- Grid de Serviços -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {siteConfig.servicos?.lista.map((servico) => (
        <article class="group bg-surface border border-border rounded-3xl p-8 hover:-translate-y-1 hover:shadow-xl hover:shadow-accent/5 transition-all duration-500">
          <div class="text-5xl mb-5">{servico.icone}</div>
          <h3 class="font-display text-2xl text-text-primary mb-3">{servico.titulo}</h3>
          <p class="text-text-secondary leading-relaxed">
            {servico.descricao}
          </p>
        </article>
      ))}
    </div>

    <!-- CTA após os serviços -->
    <div class="mt-16 md:mt-20 text-center">
      <p class="text-text-secondary text-base md:text-lg mb-6">
        {siteConfig.servicos?.ctaTexto || 'Não sabe por onde começar? Tudo bem. Conversamos juntos na primeira sessão.'}
      </p>
      <a 
        href={`https://wa.me/${siteConfig.brand.whatsapp}?text=Olá,%20gostaria%20de%20agendar%20uma%20consulta!`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 text-base font-semibold text-white bg-accent rounded-full hover:bg-accent-hover transition-all duration-300 shadow-lg shadow-accent/20"
      >
        {siteConfig.servicos?.ctaBotao || 'Agendar Primeira Consulta'}
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>