---
// src/components/sections/Hero.astro
import { siteConfig } from '../../data/site-config';
---

<section class="relative pt-24 md:pt-32 pb-16 md:pb-24 px-4 md:px-8 overflow-hidden">
  
  <!-- Elemento de fundo suave -->
  <div class="absolute top-20 right-0 w-full max-w-[500px] h-[500px] bg-accent-light rounded-full blur-3xl -z-10 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">
    
    <!-- Lado Esquerdo: Texto -->
    <div class="space-y-6 md:space-y-8 text-center md:text-left animate-slide-up">
      
      <!-- Badge -->
      <span class="inline-block px-4 py-1.5 rounded-full bg-accent-light text-accent text-xs font-semibold tracking-wide uppercase">
        {siteConfig.hero.badge}
      </span>

      <!-- Título -->
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl text-text-primary leading-[1.1]">
        {siteConfig.hero.title} <span class="italic text-accent">{siteConfig.hero.titleHighlight}</span>.
      </h1>

      <!-- Subtítulo -->
      <p class="text-text-secondary text-lg md:text-xl leading-relaxed max-w-xl mx-auto md:mx-0">
        {siteConfig.hero.subtitle}
      </p>

      <!-- Botões -->
      <div class="flex flex-col sm:flex-row items-center gap-4 pt-4 justify-center md:justify-start">
        <a 
          href={`https://wa.me/${siteConfig.brand.whatsapp}?text=Olá,%20gostaria%20de%20agendar%20uma%20consulta!`} 
          target="_blank"
          rel="noopener noreferrer"
          class="w-full sm:w-auto px-8 py-4 text-base font-semibold text-white bg-accent rounded-full hover:bg-accent-hover transition-all duration-300 shadow-lg shadow-accent/20 text-center"
        >
          {siteConfig.hero.primaryButtonText}
        </a>
        <a href="/#sobre" class="w-full sm:w-auto px-8 py-4 text-base font-semibold text-text-primary border border-border bg-surface rounded-full hover:bg-background transition-colors duration-300 text-center">
          {siteConfig.hero.secondaryButtonText}
        </a>
      </div>
    </div>

    <!-- Lado Direito: Imagem -->
    <div class="relative animate-fade-in">
      <div class="aspect-[4/5] rounded-[2rem] overflow-hidden shadow-2xl shadow-accent/10 bg-surface border border-border">
        <img 
          src={siteConfig.brand.fotoPerfil} 
          alt={`Foto de ${siteConfig.brand.name}`} 
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>
      
      <!-- Badge Flutuante: Sigilo e Ética -->
      <div class="absolute bottom-4 left-4 md:-bottom-6 md:-left-8 bg-surface border border-border p-3 md:p-4 rounded-2xl shadow-xl max-w-[220px] flex items-center gap-3">
        <div class="bg-accent-light p-2 rounded-full text-accent flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <div>
          <p class="font-semibold text-sm text-text-primary leading-tight">Sigilo e Ética</p>
          <p class="text-xs text-text-secondary mt-0.5">Ambiente 100% seguro</p>
        </div>
      </div>
    </div>

  </div>
</section>