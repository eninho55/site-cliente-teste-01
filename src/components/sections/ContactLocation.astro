---
// src/components/sections/ContactLocation.astro
import mapaTubarao from '../../assets/mapa-localizacao.png';
---

<section id="contato" class="scroll-mt-24 py-20 md:py-32 px-4 md:px-8 bg-surface relative overflow-hidden">
  
  <!-- Detalhe decorativo de fundo -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-[600px] h-[400px] bg-accent-light rounded-full blur-3xl -z-10 pointer-events-none opacity-40"></div>

  <div class="max-w-6xl mx-auto">
    
    <!-- Cabeçalho da Seção -->
    <div class="text-center max-w-2xl mx-auto mb-16 md:mb-20 space-y-4">
      <span class="inline-block px-4 py-1.5 rounded-full bg-accent-light text-accent text-xs font-semibold tracking-wide uppercase">
        Entre em Contato
      </span>
      <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-text-primary leading-tight">
        Vamos iniciar sua <span class="italic text-accent">jornada</span>?
      </h2>
      <p class="text-text-secondary text-lg leading-relaxed">
        Estou à disposição para tirar suas dúvidas e agendar sua primeira sessão, seja presencialmente em Tubarão ou de forma online.
      </p>
    </div>

    <!-- Grid: Informações + Mapa -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12 items-stretch">
      
      <!-- Coluna da Esquerda: Informações e Ações -->
      <div class="bg-background border border-border rounded-3xl p-8 md:p-10 flex flex-col justify-center space-y-8 shadow-sm">
        
        <!-- Item: Endereço Presencial -->
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-2xl bg-accent-light flex items-center justify-center text-accent flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <h3 class="font-display text-xl text-text-primary font-semibold mb-1">Consultório Presencial</h3>
            <p class="text-text-secondary leading-relaxed mb-2">
              R. José Evaristo Fogaça, 636<br />
              Vila Moema, Tubarão - SC, 88705-060
            </p>
            <a 
              href="https://www.google.com/maps?cid=10157303628408531133&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAMYASAF&hl=pt-BR&source=embed" 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-sm font-semibold text-accent hover:text-accent-hover transition-colors"
            >
              Ver rotas no Google Maps
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Item: Atendimento Online -->
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-2xl bg-accent-light flex items-center justify-center text-accent flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="14" x="2" y="5" rx="2"/>
              <line x1="2" x2="22" y1="10" y2="10"/>
            </svg>
          </div>
          <div>
            <h3 class="font-display text-xl text-text-primary font-semibold mb-1">Atendimento Online</h3>
            <p class="text-text-secondary leading-relaxed">
              Sessões por videochamada para todo o Brasil e exterior, com a mesma qualidade e sigilo do presencial.
            </p>
          </div>
        </div>

        <!-- Botão de Ação Principal (WhatsApp) -->
        <div class="pt-4">
          <a 
            href="https://wa.me/5548999973155?text=Olá,%20Fabíola!%20Gostaria%20de%20saber%20mais%20sobre%20agendamento%20de%20consultas."
            target="_blank"
            rel="noopener noreferrer"
            class="w-full flex items-center justify-center gap-3 bg-[#25D366] text-white font-semibold py-4 px-6 rounded-2xl hover:bg-[#20bd5a] transition-all duration-300 shadow-lg shadow-[#25D366]/20 text-lg"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="none">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            Agendar pelo WhatsApp
          </a>
          <p class="text-center text-xs text-text-secondary mt-3">
            Resposta em até 24 horas úteis.
          </p>
        </div>
      </div>

            <!-- Coluna da Direita: Mapa Estilizado -->
      <div class="relative rounded-3xl overflow-hidden border border-border shadow-lg h-full min-h-[400px] bg-background group">
        
        <!-- Imagem do Mapa (NÍTIDA, sem opacidade reduzida ou blur) -->
        <img 
          src={mapaTubarao.src}
          alt="Mapa da localização do consultório em Tubarão" 
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
          width="800"
          height="800"
        />
        
        <!-- Overlay sutil (apenas escurece levemente para o botão destacar, SEM borrar o mapa) -->
        <div class="absolute inset-0 bg-background/20 group-hover:bg-background/10 transition-colors duration-500 flex items-center justify-center p-6">
          <a 
            href="https://www.google.com/maps?cid=10157303628408531133&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsY2VlEAMYASAF&hl=pt-BR&source=embed"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-surface border border-border text-text-primary font-semibold py-4 px-8 rounded-2xl shadow-xl hover:scale-105 transition-transform duration-300 flex items-center gap-3"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
              <polygon points="3 11 22 2 13 21 11 13 3 11"/>
            </svg>
            Abrir no Google Maps
          </a>
        </div>
      </div>

    </div>
  </div>
</section>