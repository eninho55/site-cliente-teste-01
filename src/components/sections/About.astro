---
import { siteConfig } from '../../data/site-config';

// ✅ CORREÇÃO: Tratamento seguro da imagem e do Instagram para evitar erros de undefined
const fotoPath = typeof siteConfig.sobre?.foto === 'object' 
  ? siteConfig.sobre.foto.src 
  : (siteConfig.sobre?.foto || siteConfig.brand.logo);

// Blindagem do Instagram (remove o @ com segurança e usa fallback se necessário)
const igHandle = siteConfig.brand.instagram?.replace('@', '') || 'fabiolamedeirospsi';
const instagramUrl = `https://instagram.com/${igHandle}`;

// ✅ Construção do Schema.org Person para E-E-A-T (100% Seguro)
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": `${siteConfig.brand.profession} ${siteConfig.brand.name}`,
  "jobTitle": siteConfig.brand.profession,
  "description": siteConfig.sobre?.paragrafo1 || `Atendimento psicológico especializado com ${siteConfig.brand.name}.`,
  "image": `${siteConfig.site.url}${fotoPath}`,
  "url": siteConfig.site.url,
  "sameAs": [
    instagramUrl,
    `https://wa.me/${siteConfig.brand.whatsapp}`
  ].filter(Boolean), // Remove qualquer valor undefined por segurança
  "knowsAbout": siteConfig.sobre?.diferenciais || ["Saúde Mental", "Bem-estar", "Psicoterapia"],
  "memberOf": {
    "@type": "Organization",
    "name": "Conselho Regional de Psicologia",
    "identifier": `CRP ${siteConfig.brand.crp || 'N/A'}`
  }
};
---

<section id="sobre" class="scroll-mt-24 py-20 md:py-32 px-4 md:px-8 bg-surface relative overflow-hidden">
  
  <!-- ✅ Schema.org Person injetado na página -->
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <!-- Detalhe decorativo de fundo -->
  <div class="absolute -top-20 -left-20 w-64 h-64 bg-accent-light rounded-full blur-3xl -z-10 pointer-events-none"></div>

  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-center">
    
    <!-- Lado Esquerdo: Imagem e CRP -->
    <div class="relative flex justify-center md:justify-start">
      <!-- Moldura decorativa atrás da foto -->
      <div class="absolute top-6 -left-4 md:-left-8 w-full h-full border-2 border-accent/20 rounded-[2rem] -z-10"></div>
      
      <!-- Foto Principal -->
      <div class="relative w-full max-w-md aspect-[4/5] rounded-[2rem] overflow-hidden shadow-xl">
        <img 
          src={siteConfig.sobre.foto} 
          alt={`Foto de ${siteConfig.brand.profession} ${siteConfig.brand.name}`} 
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>

      <!-- Card do CRP -->
      <div class="absolute -bottom-6 right-4 md:-right-8 md:bottom-8 bg-background border border-border p-4 md:p-5 rounded-2xl shadow-lg max-w-[160px] md:max-w-[200px] text-center md:text-left">
        <p class="font-display text-xl md:text-2xl text-accent font-semibold">CRP {siteConfig.brand.crp}</p>
        <p class="text-xs text-text-secondary mt-1 leading-tight">Registro Profissional Ativo</p>
      </div>
    </div>

    <!-- Lado Direito: Texto -->
    <div class="space-y-6 md:space-y-8 text-center md:text-left">
      
      <div class="space-y-4">
        <span class="inline-block px-4 py-1.5 rounded-full bg-accent-light text-accent text-xs font-semibold tracking-wide uppercase">
          {siteConfig.sobre?.badge || 'Quem sou eu'}
        </span>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-text-primary leading-tight">
          {siteConfig.sobre?.titulo || 'Olá, sou a'} <span class="italic text-accent">{siteConfig.sobre?.tituloDestaque || siteConfig.brand.name}</span>.
        </h2>
      </div>

      <div class="space-y-4 text-text-secondary text-base md:text-lg leading-relaxed">
        <p>{siteConfig.sobre?.paragrafo1}</p>
        <p>{siteConfig.sobre?.paragrafo2}</p>
      </div>

      <!-- Lista de Diferenciais (Usados também no Schema "knowsAbout") -->
      <div class="pt-4 space-y-3">
        {siteConfig.sobre?.diferenciais?.map((item) => (
          <div class="flex items-center gap-3">
            <div class="w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center text-accent flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <p class="text-text-primary font-medium">{item}</p>
          </div>
        ))}
      </div>

    </div>

  </div>
</section>