---
import { siteConfig } from '../../data/site-config';

// Tratamento seguro do Instagram
const igHandle = siteConfig.brand.instagram?.replace('@', '') || 'fabiolamedeirospsi';
const instagramUrl = `https://www.instagram.com/${igHandle}/`;
---

<footer class="bg-[#1C1917] text-stone-300 pt-16 pb-8 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    
    <!-- Grid Principal -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 md:gap-8 mb-12">
      
      <!-- Coluna 1: Marca -->
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <img 
            src={siteConfig.brand.logo} 
            alt={`Logo ${siteConfig.brand.name}`} 
            class="w-10 h-10 rounded-full object-cover border border-stone-700" 
          />
          <span class="font-display text-xl font-semibold text-stone-100">{siteConfig.brand.name}</span>
        </div>
        <p class="text-sm leading-relaxed text-stone-300">
          {siteConfig.brand.profession} em {siteConfig.brand.city}. Atendimento humanizado para crianças, adolescentes e adultos, presencial e online.
        </p>
      </div>

      <!-- Coluna 2: Navegação -->
      <div>
        <h4 class="font-display text-lg font-semibold text-stone-100 mb-4">Navegação</h4>
        <ul class="space-y-3">
          <li><a href="/#inicio" class="text-sm hover:text-white transition-colors duration-300">Início</a></li>
          <li><a href="/#sobre" class="text-sm hover:text-white transition-colors duration-300">Sobre</a></li>
          <li><a href="/#servicos" class="text-sm hover:text-white transition-colors duration-300">Serviços</a></li>
          <li><a href="/#depoimentos" class="text-sm hover:text-white transition-colors duration-300">Depoimentos</a></li>
          <li><a href="/#faq" class="text-sm hover:text-white transition-colors duration-300">Dúvidas Frequentes</a></li>
          <li><a href="/blog" class="text-sm hover:text-white transition-colors duration-300">Blog</a></li>
          <li><a href="/#contato" class="text-sm hover:text-white transition-colors duration-300">Localização</a></li>
        </ul>
      </div>

      <!-- Coluna 3: Público -->
      <div>
        <h4 class="font-display text-lg font-semibold text-stone-100 mb-4">Público</h4>
        <ul class="space-y-3">
          <li><a href="/#servicos" class="text-sm hover:text-white transition-colors duration-300">Crianças</a></li>
          <li><a href="/#servicos" class="text-sm hover:text-white transition-colors duration-300">Adolescentes</a></li>
          <li><a href="/#servicos" class="text-sm hover:text-white transition-colors duration-300">Adultos</a></li>
          <li><a href="/#servicos" class="text-sm hover:text-white transition-colors duration-300">Autoestima e Autoconhecimento</a></li>
        </ul>
      </div>

      <!-- Coluna 4: Contato -->
      <div>
        <h4 class="font-display text-lg font-semibold text-stone-100 mb-4">Contato</h4>
        <ul class="space-y-4 text-sm">
          <li>
            <a href={`https://wa.me/${siteConfig.brand.whatsapp}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-white transition-colors duration-300 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#7DA0A3] group-hover:text-[#25D366] transition-colors"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {siteConfig.brand.phone}
            </a>
          </li>
          <li>
            <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-white transition-colors duration-300 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#7DA0A3] group-hover:text-[#E1306C] transition-colors"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
              {siteConfig.brand.instagram || '@fabiolamedeirospsi'}
            </a>
          </li>
          <li>
            <a href={siteConfig.brand.mapsUrl} target="_blank" rel="noopener noreferrer" class="flex items-start gap-2 hover:text-white transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0 text-[#7DA0A3]"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>{siteConfig.brand.address}</span>
            </a>
          </li>
          <li class="flex items-center gap-2 pt-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#7DA0A3]"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span class="font-medium text-stone-200">CRP {siteConfig.brand.crp}</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Barra Inferior -->
    <div class="border-t border-stone-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-stone-400">
      <span>&copy; {new Date().getFullYear()} {siteConfig.brand.name} — {siteConfig.brand.profession}. Todos os direitos reservados.</span>
      <div class="flex gap-4">
        <a href="/politica-privacidade" class="hover:text-stone-200 transition-colors">Política de Privacidade</a>
        <span>·</span>
        <span>CRP {siteConfig.brand.crp} · {siteConfig.brand.city}</span>
      </div>
    </div>
  </div>
</footer>