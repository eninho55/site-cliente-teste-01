---
import '../styles/global.css';
import { siteConfig } from '../data/site-config';

interface Props {
  title?: string;
  description?: string;
}

// Se a página passar um título personalizado, usamos ele. Senão, usamos o padrão do config.
const { 
  title = siteConfig.site.title, 
  description = siteConfig.site.description 
} = Astro.props;

const url = siteConfig.site.url;
// Fallback seguro caso a imagem de perfil não carregue por algum motivo
const imageUrl = siteConfig.brand.fotoPerfil || siteConfig.brand.logo;
const logoUrl = siteConfig.brand.logo;

// ✅ CORREÇÃO DO ERRO: Tratamento seguro do Instagram com Optional Chaining (?.)
const igHandle = siteConfig.brand.instagram?.replace('@', '') || 'fabiolamedeirospsi';
const instagramUrl = `https://www.instagram.com/${igHandle}/`;
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    
    <link rel="icon" type="image/svg+xml" href={siteConfig.brand.favicon} />
    
    <!-- SEO Básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content={siteConfig.design.themeColor} />
    
    <!-- ✅ Schema.org WebSite com SearchAction -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": siteConfig.brand.name,
      "url": url,
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${url}/blog?search={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    })} />
    
    <link rel="canonical" href={url} />

    <!-- Open Graph / Facebook -->
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:site_name" content={siteConfig.brand.name} />
    <meta property="og:image" content={imageUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <!-- Schema.org: MedicalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MedicalBusiness",
      "@id": `${url}#business`,
      "name": `Psicóloga ${siteConfig.brand.name}`,
      "alternateName": siteConfig.site.author,
      "url": url,
      "logo": logoUrl,
      "image": imageUrl,
      "description": siteConfig.site.description,
      "telephone": siteConfig.brand.phone,
      "priceRange": "$$",
      "medicalSpecialty": "Psychology",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "R. José Evaristo Fogaça, 636 - Vila Moema",
        "addressLocality": "Tubarão",
        "addressRegion": "SC",
        "postalCode": "88705-060",
        "addressCountry": "BR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "-28.4829675",
        "longitude": "-48.9959943"
      },
      "hasMap": siteConfig.brand.mapsUrl,
      "openingHoursSpecification": [{
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "08:00",
        "closes": "18:00"
      }],
      "sameAs": [
        instagramUrl, // ✅ Usa a variável segura
        siteConfig.brand.mapsUrl
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "20",
        "bestRating": "5",
        "worstRating": "1"
      }
    })} />

    <!-- Schema.org: Person -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": siteConfig.site.author,
      "jobTitle": siteConfig.brand.profession,
      "worksFor": { "@type": "MedicalBusiness", "@id": `${url}#business` },
      "url": url,
      "image": imageUrl,
      "sameAs": [instagramUrl] // ✅ Usa a variável segura
    })} />
  </head>
  <body class="flex flex-col min-h-screen overflow-x-hidden bg-background text-text-primary">
    <slot name="navbar" />
    <main class="flex-grow">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>