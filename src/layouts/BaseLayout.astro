---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = "Espaço seguro de escuta e acolhimento para crianças, adolescentes e adultos. Atendimento presencial em Tubarão/SC e online. Cuide da sua saúde mental." 
} = Astro.props;

const url = "https://fabiolapsi.com.br/";
const imageUrl = "https://lh3.googleusercontent.com/mrByRWAG_Y_SYt3ftx2zZHtZ6J79H0ccEZee1pOlQZUrPRyiRXnSrs47Cigl53guVPfpVCwUYjAASOxb=w941";
const logoUrl = "https://lh3.googleusercontent.com/a-/ALV-UjWgB_Qz22nUqMTILAauTzG1oP-C2xSTeN_nUxp4-DKuW45zw9Fz=w941";
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    
    <!-- Favicon (Certifique-se de colocar o arquivo na pasta public/) -->
    <link rel="icon" type="image/svg+xml" href="/favicon-fabiola-psicologa-tubarao-sc.svg" />
    
    <!-- SEO Básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#FAFAF9" />
    <link rel="canonical" href={url} />

    <!-- Open Graph / Facebook -->
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:site_name" content="Psicóloga Fabíola Medeiros" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:updated_time" content="2026-07-11T14:00:00+00:00" />

    <!-- Article Tags -->
    <meta property="article:published_time" content="2026-01-01T08:00:00+00:00" />
    <meta property="article:modified_time" content="2026-07-11T14:00:00+00:00" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="Psicóloga Clínica CRP 12/26596. Atendimento presencial e online. Acredite no poder da sua própria transformação." />
    <meta name="twitter:image" content={imageUrl} />

    <!-- ========================================== -->
    <!-- SCHEMA.ORG: MedicalBusiness (Negócio Local) -->
    <!-- ========================================== -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MedicalBusiness",
      "@id": `${url}#business`,
      "name": "Psicóloga Fabíola Medeiros",
      "alternateName": "Fabíola de Souza Medeiros Castro",
      "url": url,
      "logo": logoUrl,
      "image": imageUrl,
      "description": "Psicóloga clínica com atendimento para crianças, adolescentes e adultos. Terapia Cognitivo-Comportamental (TCC) em Tubarão/SC e online.",
      "telephone": "+55-48-99997-3155",
      "priceRange": "$$",
      "medicalSpecialty": "Psychology",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "R. José Evaristo Fogaça, 636 - Vila Moema",
        "addressLocality": "Tubarão",
        "addressRegion": "SC",
        "postalCode": "88705-060",
        "addressCountry": "BR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "-28.4829675",
        "longitude": "-48.9959943"
      },
      "hasMap": "https://www.google.com/maps/place/Psic%C3%B3loga+Fab%C3%ADola+Medeiros+Tubarao+SC+e+online/@-28.4830099,-48.995592,18z/data=!4m6!3m5!1s0x952143ce2e566913:0x8cf5fdd59713a8bd!8m2!3d-28.4829675!4d-48.9959943!16s%2Fg%2F11y6pfdq4b",
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "08:00",
          "closes": "18:00"
        }
      ],
      "sameAs": [
        "https://www.instagram.com/fabiolamedeirospsi/",
        "https://www.google.com/maps/place/Psic%C3%B3loga+Fab%C3%ADola+Medeiros+Tubarao+SC+e+online/@-28.4830099,-48.995592,18z/data=!4m6!3m5!1s0x952143ce2e566913:0x8cf5fdd59713a8bd!8m2!3d-28.4829675!4d-48.9959943!16s%2Fg%2F11y6pfdq4b"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Serviços de Psicologia",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "MedicalTherapy", "name": "Psicologia Infantil", "description": "Atendimento lúdico e acolhedor para crianças" } },
          { "@type": "Offer", "itemOffered": { "@type": "MedicalTherapy", "name": "Terapia para Adolescentes", "description": "Espaço de escuta para demandas da adolescência" } },
          { "@type": "Offer", "itemOffered": { "@type": "MedicalTherapy", "name": "Terapia para Adultos", "description": "Terapia individual focada em ansiedade, estresse e autoconhecimento" } },
          { "@type": "Offer", "itemOffered": { "@type": "MedicalTherapy", "name": "Atendimento Online", "description": "Consultas por videochamada" } },
          { "@type": "Offer", "itemOffered": { "@type": "MedicalTherapy", "name": "Autoestima e Autoconhecimento", "description": "Desenvolvimento pessoal e fortalecimento da autoestima" } }
        ]
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "20",
        "bestRating": "5",
        "worstRating": "1"
      },
      "review": [
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Isabela Farias" },
          "datePublished": "2024-09-26",
          "reviewBody": "Querida e com um olhar que transmite acolhimento. É uma profissional competente, atende com tranquilidade, permitindo que o paciente se expresse e demonstra uma escuta muito atenta.",
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Jaime Alves" },
          "datePublished": "2024-07-18",
          "reviewBody": "Ótima profissional, trata minha filha de 8 anos, com muita paciência e carinho, super recomendo.",
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Isabella de Souza Costa" },
          "datePublished": "2026-05-11",
          "reviewBody": "Excelente profissional! Muito atenciosa, humana e cuidadosa no acompanhamento. Minha filha se sente acolhida e tivemos mudanças muito positivas após o início das consultas. Recomendo muito!",
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        }
      ]
    })} />

    <!-- ========================================== -->
    <!-- SCHEMA.ORG: Person (Profissional) -->
    <!-- ========================================== -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Fabíola de Souza Medeiros Castro",
      "jobTitle": "Psicóloga Clínica",
      "worksFor": {
        "@type": "MedicalBusiness",
        "@id": `${url}#business`,
        "name": "Psicóloga Fabíola Medeiros"
      },
      "url": url,
      "image": imageUrl,
      "sameAs": ["https://www.instagram.com/fabiolamedeirospsi/"],
      "knowsAbout": ["Psicologia Infantil", "Psicologia Adolescente", "Terapia Cognitivo-Comportamental", "Ansiedade", "Depressão", "Autoconhecimento"]
    })} />

  </head>
  <body class="flex flex-col min-h-screen overflow-x-hidden bg-background text-text-primary">
    <slot name="navbar" />
    <main class="flex-grow">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>