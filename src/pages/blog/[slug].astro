---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { siteConfig } from '../../data/site-config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;

// No Astro v6, use a função render() importada
const { Content } = await render(post);

// URL base do site
const siteUrl = siteConfig.site.url;

// Schema.org Article markup com ImageObject completo
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.excerpt,
  "author": {
    "@type": "Person",
    "name": siteConfig.site.author,
    "jobTitle": siteConfig.brand.profession,
    "url": siteUrl
  },
  "publisher": {
    "@type": "MedicalBusiness",
    "name": `Psicóloga ${siteConfig.brand.name}`,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}${siteConfig.brand.logo}`
    }
  },
  "datePublished": post.data.date,
  "dateModified": post.data.date,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/blog/${post.id}`
  },
  "articleSection": post.data.category,
  // ✅ CORREÇÃO DE SEGURANÇA: Fallback para "5 min" se readTime estiver vazio
  "timeRequired": `PT${(post.data.readTime || "5 min").replace(' min', '')}M`,
  
  // ✅ Schema.org ImageObject completo para SEO
  ...(post.data.image && {
    "image": {
      "@type": "ImageObject",
      "url": `${siteUrl}${post.data.image.src}`,
      "width": post.data.image.width,
      "height": post.data.image.height,
      "contentUrl": `${siteUrl}${post.data.image.src}`,
      "description": post.data.imageCaption || post.data.excerpt,
      "caption": post.data.title,
      "author": {
        "@type": "Person",
        "name": siteConfig.site.author
      },
      "copyrightHolder": {
        "@type": "Person",
        "name": `Psicóloga ${siteConfig.brand.name}`
      },
      "acquireLicensePage": `${siteUrl}/politica-privacidade`,
      "license": "https://creativecommons.org/licenses/by-nc-nd/4.0/"
    }
  })
};

// Schema.org BreadcrumbList markup
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Início",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": `${siteUrl}/blog`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": post.data.category,
      "item": `${siteUrl}/blog`
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": post.data.title,
      "item": `${siteUrl}/blog/${post.id}`
    }
  ]
};
---

<BaseLayout
  title={`${post.data.title} | ${siteConfig.brand.name}`}
  description={post.data.excerpt}
>
  <article class="max-w-3xl mx-auto px-4 md:px-8 py-16 md:py-24" transition:animate="fade" transition:duration="300ms">
    
    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    
    <!-- ✅ Breadcrumbs de Navegação -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-text-secondary flex-wrap">
        <li class="flex items-center gap-2">
          <a href="/" class="hover:text-accent transition-colors">Início</a>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </li>
        <li class="flex items-center gap-2">
          <a href="/blog" class="hover:text-accent transition-colors">Blog</a>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </li>
        <li class="flex items-center gap-2">
          <a href={`/blog/categoria/${post.data.category.toLowerCase()}/`} class="hover:text-accent transition-colors">
            {post.data.category}
          </a>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </li>
        
      </ol>
    </nav>

    <!-- Header do Artigo -->
    <header class="mb-8 md:mb-10 text-center">
      <span class="inline-block px-4 py-1.5 rounded-full bg-accent-light text-accent text-xs font-semibold tracking-wide uppercase mb-4">
        {post.data.category}
      </span>
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl text-text-primary leading-tight mb-6">
        {post.data.title}
      </h1>
      
      <!-- Meta Informações -->
      <div class="flex items-center justify-center gap-4 text-sm text-text-secondary flex-wrap">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
            <line x1="16" x2="16" y1="2" y2="6"/>
            <line x1="8" x2="8" y1="2" y2="6"/>
            <line x1="3" x2="21" y2="10" y1="10"/>
          </svg>
          <time datetime={post.data.date}>{post.data.date}</time>
        </div>
        <span>•</span>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <span>{post.data.readTime} de leitura</span>
        </div>
        <span>•</span>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <span>{siteConfig.brand.name}</span>
        </div>
      </div>
    </header>

    {/* ✅ Hero Image (Blindado: só renderiza se a imagem existir de verdade) */}
    {post.data.image?.src && (
      <figure class="mb-10 md:mb-12">
        <div class="rounded-2xl overflow-hidden shadow-xl border border-border bg-muted">
          <img 
            src={post.data.image.src} 
            alt={post.data.imageCaption || post.data.title}
            width={post.data.image.width}
            height={post.data.image.height}
            class="w-full h-auto object-cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </figure>
    )}

    <!-- ✅ Conteúdo do Artigo (LIMPO: O global.css faz a mágica acontecer aqui) -->
    <div class="prose prose-stone max-w-none">
       <Content />
    </div>

    <!-- CTA Final -->
    <div class="mt-12 md:mt-16 bg-surface border border-border rounded-3xl p-8 md:p-10 text-center">
      <h2 class="font-display text-2xl md:text-3xl text-text-primary mb-4">
        Gostou deste conteúdo?
      </h2>
      <p class="text-text-secondary mb-6 max-w-xl mx-auto">
        A terapia é o próximo passo para transformar essa informação em bem-estar real.
      </p>
      <a 
        href={`https://wa.me/${siteConfig.brand.whatsapp}?text=Olá,%20gostaria%20de%20agendar%20uma%20consulta!`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 text-base font-bold bg-accent rounded-full hover:bg-accent-hover transition-all duration-300 shadow-lg shadow-accent/20"
        style="color: white !important;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="color: white;">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Agendar minha consulta
      </a>
    </div>

    <!-- ✅ Botão de Voltar para o Blog -->
    <div class="mt-10 text-center">
      <a href="/blog" class="inline-flex items-center gap-2 text-accent hover:text-accent-hover font-medium transition-colors bg-accent-light/30 px-6 py-3 rounded-full hover:bg-accent-light/50">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Voltar para todos os artigos
      </a>
    </div>
  </article>
</BaseLayout>