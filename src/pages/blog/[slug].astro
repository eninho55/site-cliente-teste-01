---
// src/pages/blog/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts } from '../../data/blog';
import { siteConfig } from '../../data/site-config';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

// Schema.org Article markup
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": post.excerpt,
  "author": {
    "@type": "Person",
    "name": siteConfig.site.author,
    "jobTitle": siteConfig.brand.profession,
    "url": siteConfig.site.url
  },
  "publisher": {
    "@type": "MedicalBusiness",
    "name": `Psicóloga ${siteConfig.brand.name}`,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteConfig.site.url}${siteConfig.brand.logo}`
    }
  },
  "datePublished": post.date,
  "dateModified": post.date,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteConfig.site.url}/blog/${post.slug}`
  },
  "articleSection": post.category,
  "timeRequired": `PT${post.readTime.replace(' min', '')}M`
};
---

<BaseLayout
  title={`${post.title} | ${siteConfig.brand.name}`}
  description={post.excerpt}
>
<article class="max-w-3xl mx-auto px-4 md:px-8 py-16 md:py-24" transition:animate="fade" transition:duration="300ms">    
    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    
    <!-- Header do Artigo -->
    <header class="mb-10 md:mb-12 text-center">
      <span class="inline-block px-4 py-1.5 rounded-full bg-accent-light text-accent text-xs font-semibold tracking-wide uppercase mb-4">
        {post.category}
      </span>
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl text-text-primary leading-tight mb-6">
        {post.title}
      </h1>
      
      <!-- Meta Informações -->
      <div class="flex items-center justify-center gap-4 text-sm text-text-secondary flex-wrap">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
            <line x1="16" x2="16" y1="2" y2="6"/>
            <line x1="8" x2="8" y1="2" y2="6"/>
            <line x1="3" x2="21" y2="10" y1="10"/>
          </svg>
          <time datetime={post.date}>{post.date}</time>
        </div>
        <span>•</span>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <span>{post.readTime} de leitura</span>
        </div>
        <span>•</span>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <span>{siteConfig.brand.name}</span>
        </div>
      </div>
    </header>

    <!-- Conteúdo do Artigo -->
    <div 
      class="prose prose-stone max-w-none prose-headings:font-display prose-headings:text-text-primary prose-headings:font-semibold prose-h2:text-2xl prose-h2:mt-8 prose-h2:mb-4 prose-p:text-text-secondary prose-p:mb-4 prose-a:text-accent prose-strong:text-text-primary prose-ul:my-6 prose-ol:my-6 prose-li:mb-2 prose-blockquote:border-l-4 prose-blockquote:border-accent prose-blockquote:pl-4 prose-blockquote:italic prose-blockquote:my-8 prose-blockquote:bg-accent-light/20 prose-blockquote:py-4 prose-blockquote:px-6 prose-blockquote:rounded-r-lg"
      set:html={post.content}
    />

    <!-- CTA Final -->
    <div class="mt-12 md:mt-16 bg-surface border border-border rounded-3xl p-8 md:p-10 text-center">
      <h2 class="font-display text-2xl md:text-3xl text-text-primary mb-4">
        Gostou deste conteúdo?
      </h2>
      <p class="text-text-secondary mb-6 max-w-xl mx-auto">
        A terapia é o próximo passo para transformar essa informação em bem-estar real.
      </p>
      <a 
        href={`https://wa.me/${siteConfig.brand.whatsapp}?text=Olá,%20gostaria%20de%20agendar%20uma%20consulta!`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 text-base font-semibold text-white bg-accent rounded-full hover:bg-accent-hover transition-all duration-300 shadow-lg shadow-accent/20"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="none">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Agendar minha consulta
      </a>
    </div>

    <!-- Voltar para o Blog -->
    <div class="mt-10 text-center">
      <a href="/blog" class="inline-flex items-center gap-2 text-accent hover:text-accent-hover font-medium transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Voltar para todos os artigos
      </a>
    </div>
  </article>
</BaseLayout>