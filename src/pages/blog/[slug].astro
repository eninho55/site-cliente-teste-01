---
// src/pages/blog/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/sections/Navbar.astro';
import Footer from '../../components/sections/Footer.astro';
import { blogPosts } from '../../data/blog';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<BaseLayout title={`${post.title} | Blog Psicóloga Fabíola Medeiros`}>
  <Navbar slot="navbar" />
  
  <main class="overflow-x-hidden">
    <article class="pt-32 pb-20 px-4 md:px-8 bg-background min-h-screen">
      <div class="max-w-3xl mx-auto">
        
        <!-- Link de Voltar -->
        <a href="/blog" class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent transition-colors mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Voltar para o Blog
        </a>

        <!-- Cabeçalho do Artigo -->
        <header class="mb-10 space-y-6">
          <span class="inline-block px-4 py-1.5 rounded-full bg-accent/10 text-accent text-xs font-semibold tracking-wide uppercase">
            {post.category}
          </span>
          <h1 class="font-display text-3xl sm:text-4xl md:text-5xl text-text-primary leading-tight">
            {post.title}
          </h1>
          <div class="flex items-center gap-4 text-sm text-text-secondary border-b border-border pb-6">
            <span>📅 {post.date}</span>
            <span>•</span>
            <span>⏱️ {post.readTime} de leitura</span>
          </div>
        </header>

        <!-- Conteúdo do Artigo -->
        <div class="prose prose-stone max-w-none prose-headings:font-display prose-headings:text-text-primary prose-p:text-text-secondary prose-p:leading-relaxed prose-a:text-accent hover:prose-a:text-accent-hover" set:html={post.content} />

        <!-- CTA no final do artigo -->
        <div class="mt-16 bg-accent-light/30 rounded-3xl p-8 md:p-10 text-center border border-accent/10">
          <h3 class="font-display text-2xl text-text-primary font-semibold mb-3">Gostou deste conteúdo?</h3>
          <p class="text-text-secondary mb-6">A terapia é o próximo passo para transformar essa informação em bem-estar real.</p>
          <a 
            href="https://wa.me/5548999973155?text=Olá,%20Fabíola!%20Li%20seu%20artigo%20e%20gostaria%20de%20agendar%20uma%20consulta." 
            target="_blank" 
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-8 py-4 text-base font-semibold text-white bg-[#25D366] rounded-full hover:bg-[#20bd5a] transition-all duration-300 shadow-lg shadow-[#25D366]/20"
          >
            Agendar minha consulta
          </a>
        </div>

      </div>
    </article>
  </main>

  <Footer slot="footer" />
</BaseLayout>