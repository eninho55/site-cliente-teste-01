---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../../../data/site-config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // Extrair categorias únicas
  const categories = [...new Set(posts.map((post) => post.data.category))];
  
  return categories.map((category) => ({
    params: { categoria: category.toLowerCase() },
    props: { 
      category, 
      posts: posts.filter((post) => post.data.category === category) 
    },
  }));
}

const { category, posts } = Astro.props;

// Ordenar por data (mais recente primeiro)
posts.sort((a, b) => {
  const dateA = new Date(a.data.date).getTime() || 0;
  const dateB = new Date(b.data.date).getTime() || 0;
  return dateB - dateA;
});
---

<BaseLayout
  title={`Categoria: ${category} | Blog | ${siteConfig.brand.name}`}
  description={`Artigos e dicas sobre ${category.toLowerCase()} com a ${siteConfig.brand.profession} ${siteConfig.brand.name}.`}
>
  <section class="max-w-6xl mx-auto px-4 md:px-8 py-16 md:py-24" transition:animate="fade" transition:duration="300ms">
    
    <!-- Cabeçalho com Navegação de Volta -->
    <header class="text-center mb-12 md:mb-16">
      <a href="/blog" class="inline-flex items-center gap-2 text-accent hover:text-accent-hover font-medium transition-colors mb-6 mx-auto w-fit">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Voltar para todos os artigos
      </a>
      
      <span class="inline-block px-4 py-1.5 rounded-full bg-accent-light text-accent text-xs font-semibold tracking-wide uppercase mb-4">
        Categoria
      </span>
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl text-text-primary leading-tight mb-4">
        {category}
      </h1>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">
        Confira todos os artigos e conteúdos relacionados a {category.toLowerCase()}.
      </p>
    </header>

    <!-- Grid de Artigos -->
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a 
            href={`/blog/${post.id}/`} 
            class="group block bg-surface border border-border rounded-2xl overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
          >
            {post.data.image ? (
              <div class="aspect-video w-full overflow-hidden bg-muted">
                <img 
                  src={post.data.image.src} 
                  alt={post.data.imageCaption || post.data.title}
                  width={post.data.image.width}
                  height={post.data.image.height}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="aspect-video w-full bg-gradient-to-br from-accent-light/50 to-accent-light/20 flex items-center justify-center">
                <span class="text-6xl group-hover:scale-110 transition-transform duration-500">
                  {post.data.emoji || '📝'}
                </span>
              </div>
            )}
            
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="px-3 py-1 text-xs font-semibold bg-accent-light text-accent rounded-full">
                  {post.data.category}
                </span>
                <span class="text-xs text-text-secondary">{post.data.date}</span>
              </div>
              
              <h2 class="font-display text-xl text-text-primary font-semibold mb-3 group-hover:text-accent transition-colors line-clamp-2">
                {post.data.title}
              </h2>
              
              <p class="text-text-secondary text-sm line-clamp-3 mb-4 leading-relaxed">
                {post.data.excerpt}
              </p>
              
              <div class="flex items-center justify-between text-sm">
                <span class="text-text-secondary">{post.data.readTime} de leitura</span>
                <span class="text-accent font-medium group-hover:underline flex items-center gap-1">
                  Ler mais
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-16 bg-surface border border-border rounded-2xl">
        <p class="text-text-secondary text-lg mb-4">Nenhum artigo encontrado nesta categoria no momento.</p>
        <a href="/blog" class="inline-flex items-center gap-2 text-accent hover:text-accent-hover font-medium transition-colors">
          Ver todos os artigos
        </a>
      </div>
    )}

  </section>
</BaseLayout>