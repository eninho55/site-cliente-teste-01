---
// src/pages/blog.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/sections/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
import { blogPosts } from '../data/blog';

// Ordenar posts do mais recente para o mais antigo
const sortedPosts = blogPosts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout title="Blog | Psicóloga Fabíola Medeiros - Artigos sobre Saúde Mental">
  <Navbar slot="navbar" />
  
  <main class="overflow-x-hidden">
    <!-- Cabeçalho do Blog -->
    <section class="pt-32 pb-16 md:pt-40 md:pb-24 px-4 md:px-8 bg-accent-light/30 text-center">
      <div class="max-w-3xl mx-auto space-y-4">
        <span class="inline-block px-4 py-1.5 rounded-full bg-accent/10 text-accent text-xs font-semibold tracking-wide uppercase">
          Conteúdo Especializado
        </span>
        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl text-text-primary leading-tight">
          Blog & <span class="italic text-accent">Artigos</span>
        </h1>
        <p class="text-text-secondary text-lg md:text-xl leading-relaxed">
          Dicas e reflexões sobre psicologia infantil, adolescentes e bem-estar emocional para ajudar você e sua família.
        </p>
      </div>
    </section>

    <!-- Grid de Artigos -->
    <section class="py-16 md:py-24 px-4 md:px-8 bg-background">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedPosts.map((post) => (
          <article class="group bg-surface border border-border rounded-3xl overflow-hidden hover:-translate-y-2 hover:shadow-xl hover:shadow-accent/5 transition-all duration-500 flex flex-col">
            <a href={`/blog/${post.slug}`} class="flex flex-col h-full">
              <div class="h-48 bg-accent-light/50 flex items-center justify-center text-6xl group-hover:scale-105 transition-transform duration-500">
                {post.emoji}
              </div>
              <div class="p-8 flex flex-col flex-grow">
                <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-semibold uppercase tracking-wide w-fit mb-4">
                  {post.category}
                </span>
                <h3 class="font-display text-xl text-text-primary font-semibold mb-3 group-hover:text-accent transition-colors">
                  {post.title}
                </h3>
                <div class="flex items-center gap-3 text-xs text-text-secondary mb-4">
                  <span>📅 {post.date}</span>
                  <span>•</span>
                  <span>⏱️ {post.readTime}</span>
                </div>
                <p class="text-text-secondary text-sm leading-relaxed mb-6 flex-grow">
                  {post.excerpt}
                </p>
                <span class="inline-flex items-center gap-2 text-sm font-semibold text-accent group-hover:gap-3 transition-all">
                  Ler artigo completo 
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>

    <!-- CTA Final -->
    <section class="py-16 md:py-24 px-4 md:px-8 bg-surface border-t border-border">
      <div class="max-w-3xl mx-auto text-center bg-accent-light/30 rounded-3xl p-8 md:p-12 border border-accent/10">
        <h2 class="font-display text-2xl md:text-3xl text-text-primary font-semibold mb-4">
          Precisa de ajuda profissional?
        </h2>
        <p class="text-text-secondary mb-8 max-w-xl mx-auto">
          Se você identificou algum desses sinais em seu filho ou em você mesmo, estou aqui para ajudar. Vamos conversar.
        </p>
        <a 
          href="https://wa.me/5548999973155?text=Olá,%20Fabíola!%20Vi%20seu%20blog%20e%20gostaria%20de%20agendar%20uma%20consulta." 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 text-base font-semibold text-white bg-[#25D366] rounded-full hover:bg-[#20bd5a] transition-all duration-300 shadow-lg shadow-[#25D366]/20"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          Agendar Consulta
        </a>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</BaseLayout>